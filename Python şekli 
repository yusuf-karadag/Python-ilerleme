for i in range(1, 11):
    total = total + i

print("Total:", total)

# 5. Multiplication table
print("\n--- Multiplication table of 5 ---")

for i in range(1, 11):
    print("5 x", i, "=", 5 * i)

# 6. Print letters of a word
print("\n--- Letters of the word 'YUSUF' ---")

for letter in "YUSUF":
    print(letter)

# 7. Print squares of numbers
print("\n--- Squares of numbers ---")

